    <Match>
        <Class name="~org\.wso2\.carbon\.container.*"/>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
    </Match>
    <Match>
        <Class name="~org\.wso2\.carbon\.container.*"/>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
    </Match>

    <Match>
        <Class name="org.wso2.carbon.container.ArchiveExtractor" />
